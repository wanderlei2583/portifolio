---
const projects = [
	{
		title: "RateLimiter",
		description: "Implementação de rate limiting em Go para controle de tráfego e estabilidade de APIs.",
		techs: ["Go"],
		link: "https://github.com/wanderlei2583/RateLimiter",
		color: "border-blue-500/30 hover:border-blue-500/60"
	},
	{
		title: "Tracing",
		description: "Projeto em Go focado em rastreamento e observabilidade de aplicações.",
		techs: ["Go"],
		link: "https://github.com/wanderlei2583/tracing",
		color: "border-blue-500/30 hover:border-blue-500/60"
	},
	{
		title: "Controle de Vendas",
		description: "Aplicação em Dart para gestão e organização de vendas.",
		techs: ["Dart"],
		link: "https://github.com/wanderlei2583/controle_vendas",
		color: "border-emerald-500/30 hover:border-emerald-500/60"
	},
	{
		title: "Landing Page 02",
		description: "Landing page em HTML com layout responsivo e foco em conversão.",
		techs: ["HTML"],
		link: "https://github.com/wanderlei2583/landpage02",
		color: "border-orange-500/30 hover:border-orange-500/60"
	},
	{
		title: "Clean Architecture",
		description: "Projeto em Go organizado em camadas seguindo Clean Architecture.",
		techs: ["Go"],
		link: "https://github.com/wanderlei2583/cleanArquiteture",
		color: "border-blue-500/30 hover:border-blue-500/60"
	},
	{
		title: "IMC Flutter",
		description: "App em Flutter para cálculo de IMC com interface simples.",
		techs: ["Flutter", "C++"],
		link: "https://github.com/wanderlei2583/imc_flutter",
		color: "border-teal-500/30 hover:border-teal-500/60"
	},
	{
		title: "Auction Leilão",
		description: "Sistema de leilão em Go com foco em regras de negócio.",
		techs: ["Go"],
		link: "https://github.com/wanderlei2583/auction_leilao",
		color: "border-blue-500/30 hover:border-blue-500/60"
	},
	{
		title: "Clima CEP",
		description: "Consulta de clima por CEP em Go com integração externa.",
		techs: ["Go"],
		link: "https://github.com/wanderlei2583/clima_cep",
		color: "border-blue-500/30 hover:border-blue-500/60"
	},
	{
		title: "Gerador de Códigos de Barras",
		description: "Gerador de códigos de barras para rastreamento de objetos.",
		techs: ["Python"],
		link: "https://github.com/wanderlei2583/geradorCodigosBarras",
		color: "border-yellow-500/30 hover:border-yellow-500/60"
	}
];
---

<section id="projetos" class="container mx-auto px-4 py-16">
    <div class="flex items-center gap-4 mb-12">
        <div class="h-px bg-slate-700 flex-1"></div>
        <h2 class="text-3xl font-bold text-center text-slate-100">Projetos em Destaque</h2>
        <div class="h-px bg-slate-700 flex-1"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
            <div class={`bg-slate-800/50 backdrop-blur-sm rounded-xl p-6 transition-all duration-300 border ${project.color} hover:-translate-y-1 hover:shadow-xl group`}>
                <h3 class="text-xl font-bold mb-3 text-slate-100 group-hover:text-white transition-colors">{project.title}</h3>
                <p class="text-slate-400 mb-6 leading-relaxed text-sm">{project.description}</p>
                
                <div class="flex flex-wrap gap-2 mb-6">
                    {project.techs.map((tech) => (
                        <span class="bg-slate-700/50 text-xs font-mono px-2 py-1 rounded border border-slate-600/50 text-slate-300">
                            {tech}
                        </span>
                    ))}
                </div>
                
                <a href={project.link} class="inline-flex items-center text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors">
                    Ver Código <span class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
                </a>
            </div>
        ))}
    </div>
</section>
