---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Projects from '../components/Projects.astro';
import Studies from '../components/Studies.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Portifólio">
	<main class="min-h-screen bg-slate-900">
		<!-- Background Grid Effect -->
		<div class="fixed inset-0 bg-[url('/background.svg')] bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] opacity-20 pointer-events-none"></div>
		
		<div class="relative z-10">
			<Header />
			<Projects />
			<Studies />
			<Contact />
		</div>
	</main>
</Layout>
